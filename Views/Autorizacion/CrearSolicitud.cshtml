@model TheBuryProject.ViewModels.CrearSolicitudAutorizacionViewModel

@{
    ViewData["Title"] = "Crear Solicitud de Autorización";
}

<div class="container-fluid px-0">

    <!-- Header de página -->
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <div class="text-muted text-uppercase small mb-1">Autorizaciones</div>
            <h1 class="h4 mb-1">Crear solicitud de autorización</h1>
            <p class="text-muted small mb-0">
                Solicita autorización para operaciones que exceden tus límites permitidos.
            </p>
        </div>

        <a asp-action="Solicitudes" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Volver a solicitudes
        </a>
    </div>

    <div class="row">
        <div class="col-12 col-lg-8 col-xl-6">

            <div class="card card-animate">
                <div class="card-body">

                    <form asp-action="CrearSolicitud" method="post" novalidate>
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                        <!-- Tipo de Umbral -->
                        <div class="mb-3">
                            <label asp-for="TipoUmbral" class="form-label"></label>
                            <select asp-for="TipoUmbral"
                                    class="form-select"
                                    asp-items="Html.GetEnumSelectList<TheBuryProject.Models.Entities.TipoUmbral>()"
                                    required>
                                <option value="">Seleccione un tipo...</option>
                            </select>
                            <span asp-validation-for="TipoUmbral" class="text-danger small"></span>
                            <div class="form-text">
                                Seleccione el tipo de operación que requiere autorización.
                            </div>
                        </div>

                        <!-- Valor Solicitado -->
                        <div class="mb-3">
                            <label asp-for="ValorSolicitado" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="ValorSolicitado"
                                       class="form-control"
                                       type="number"
                                       step="0.01"
                                       min="0"
                                       required />
                            </div>
                            <span asp-validation-for="ValorSolicitado" class="text-danger small d-block"></span>
                            <div class="form-text">
                                Ingrese el valor de la operación que desea autorizar.
                            </div>
                        </div>

                        <!-- Tipo de Operación -->
                        <div class="mb-3">
                            <label asp-for="TipoOperacion" class="form-label"></label>
                            <select asp-for="TipoOperacion" class="form-select" required>
                                <option value="">Seleccione un tipo...</option>
                                <option value="Venta">Venta</option>
                                <option value="Descuento">Descuento</option>
                                <option value="Devolucion">Devolución</option>
                                <option value="Compra">Compra</option>
                                <option value="Pago">Pago</option>
                                <option value="Otro">Otro</option>
                            </select>
                            <span asp-validation-for="TipoOperacion" class="text-danger small"></span>
                            <div class="form-text">
                                Tipo de operación que requiere autorización.
                            </div>
                        </div>

                        <!-- Referencia Operación -->
                        <div class="mb-3">
                            <label asp-for="ReferenciaOperacionId" class="form-label"></label>
                            <input asp-for="ReferenciaOperacionId"
                                   class="form-control"
                                   type="number"
                                   min="0" />
                            <span asp-validation-for="ReferenciaOperacionId" class="text-danger small"></span>
                            <div class="form-text">
                                ID de la operación relacionada (opcional, si aplica).
                            </div>
                        </div>

                        <!-- Justificación -->
                        <div class="mb-3">
                            <label asp-for="Justificacion" class="form-label"></label>
                            <textarea asp-for="Justificacion"
                                      class="form-control"
                                      rows="4"
                                      minlength="20"
                                      maxlength="1000"
                                      required
                                      placeholder="Explique detalladamente el motivo de la solicitud (mínimo 20 caracteres)..."></textarea>
                            <span asp-validation-for="Justificacion" class="text-danger small"></span>
                            <div class="form-text">
                                Proporcione una justificación detallada para la solicitud (20-1000 caracteres).
                            </div>
                        </div>

                        <!-- Botones -->
                        <div class="d-flex justify-content-end gap-2 mt-4">
                            <a asp-action="Solicitudes" class="btn btn-outline-secondary">
                                <i class="bi bi-x-lg me-1"></i>Cancelar
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send me-1"></i>Enviar solicitud
                            </button>
                        </div>
                    </form>

                </div>
            </div>

            <!-- Información adicional -->
            <div class="card mt-3">
                <div class="card-body">
                    <h6 class="card-title mb-3">
                        <i class="bi bi-info-circle me-2"></i>Información
                    </h6>
                    <ul class="list-unstyled mb-0 small text-muted">
                        <li class="mb-2">
                            <i class="bi bi-check2 text-success me-2"></i>
                            Una vez enviada la solicitud, será revisada por un superior.
                        </li>
                        <li class="mb-2">
                            <i class="bi bi-check2 text-success me-2"></i>
                            Recibirá notificación cuando la solicitud sea aprobada o rechazada.
                        </li>
                        <li>
                            <i class="bi bi-check2 text-success me-2"></i>
                            Proporcione una justificación detallada para facilitar la aprobación.
                        </li>
                    </ul>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
